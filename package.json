{
  "name": "clawnductor",
  "version": "1.0.6",
  "description": "Weaponize Claude Code from OpenClaw — persistent sessions, multi-agent ensembles, ultraplan, and fleet review. No external dependencies.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  },
  "files": [
    "dist/",
    "configs/",
    "skills/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/tests/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  }
}
